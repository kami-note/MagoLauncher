<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MagoLauncher.Presentation.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MagoLauncher.Presentation.Views.HomeView"
             x:DataType="vm:HomeViewModel">
    <Grid RowDefinitions="Auto, *" Margin="40,30">
        <!-- Top Bar / Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding SelectedInstance.Name, FallbackValue='Mago Launcher'}" 
                           FontSize="28" FontWeight="Bold" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#27272a" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="{Binding SelectedInstance.MinecraftVersion, StringFormat='Versão {0}', FallbackValue='Nenhuma instância selecionada'}" 
                                   FontSize="12" Foreground="#a1a1aa"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Center Content Area -->
        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="32">
                <!-- Instance Hero Icon -->
                <Border Width="120" Height="120" CornerRadius="30" Background="#27272a" 
                        BoxShadow="0 10 30 0 #40000000" HorizontalAlignment="Center">
                    <material:MaterialIcon Kind="Controller" Width="56" Height="56" Foreground="#8b5cf6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Instance Info (RAM removed from here) -->
                <Border Background="#27272a" CornerRadius="16" Padding="32,24" 
                        HorizontalAlignment="Center" MinWidth="400">
                    <StackPanel Spacing="20">
                        <TextBlock Text="DETALHES DA INSTÂNCIA" FontSize="11" FontWeight="Bold" 
                                   Foreground="#71717a" LetterSpacing="1"/>

                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon Kind="InformationOutline" Width="16" Height="16" Foreground="#a1a1aa"/>
                                <TextBlock Text="Informações" FontSize="13" Foreground="#d4d4d8"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedInstance.MinecraftVersion, StringFormat='Minecraft {0}'}" 
                                       FontSize="14" Foreground="White" FontWeight="Medium"/>
                             <TextBlock Text="{Binding SelectedInstance.ModLoaderType, StringFormat='Loader: {0}'}" 
                                       FontSize="12" Foreground="#a1a1aa"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
