<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MagoLauncher.Presentation.ViewModels"
        xmlns:controls="using:MagoLauncher.Presentation.Controls"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="using:MagoLauncher.Presentation.Converters"
        xmlns:views="using:MagoLauncher.Presentation.Views"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="MagoLauncher.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="MagoLauncher"
        Width="1000" Height="650"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="40"
        Background="{StaticResource SteamDarkBackground}">

    <Window.Styles>
        <Style Selector="Button.TopBarNavButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.TopBarNavButton TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SteamTextSecondary}"/>
        </Style>
        <Style Selector="Button.TopBarNavButton:pointerover TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Window.Resources>
        <converters:ActiveViewToForegroundConverter x:Key="ActiveViewToForegroundConverter"/>
        <converters:ActiveViewToUnderlineConverter x:Key="ActiveViewToUnderlineConverter"/>
    </Window.Resources>
        
    <Grid RowDefinitions="40, *">
        <!-- Main Application Header (Steam Top Bar) -->
        <Border Grid.Row="0" Background="{StaticResource SteamHeaderBackground}" Padding="16,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Navigation Links (Store, Library, etc) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="32" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Button Classes="TopBarNavButton" Command="{Binding GoToStoreCommand}">
                        <TextBlock Text="LOJA" 
                                   Foreground="{Binding ActiveView, Converter={StaticResource ActiveViewToForegroundConverter}, ConverterParameter=Store}"
                                   TextDecorations="{Binding ActiveView, Converter={StaticResource ActiveViewToUnderlineConverter}, ConverterParameter=Store}"/>
                    </Button>
                    <Button Classes="TopBarNavButton" Command="{Binding GoToHomeCommand}">
                        <TextBlock Text="BIBLIOTECA" 
                                   Foreground="{Binding ActiveView, Converter={StaticResource ActiveViewToForegroundConverter}, ConverterParameter=Home}"
                                   TextDecorations="{Binding ActiveView, Converter={StaticResource ActiveViewToUnderlineConverter}, ConverterParameter=Home}"/>
                    </Button>
                    <Button Classes="TopBarNavButton"> <!-- Community -->
                        <TextBlock Text="COMUNIDADE" 
                                   Foreground="{Binding ActiveView, Converter={StaticResource ActiveViewToForegroundConverter}, ConverterParameter=Community}"
                                   TextDecorations="{Binding ActiveView, Converter={StaticResource ActiveViewToUnderlineConverter}, ConverterParameter=Community}"/>
                    </Button>
                    <Button Classes="TopBarNavButton"> <!-- User -->
                        <TextBlock Text="USUÁRIO" 
                                   Foreground="{Binding ActiveView, Converter={StaticResource ActiveViewToForegroundConverter}, ConverterParameter=User}"
                                   TextDecorations="{Binding ActiveView, Converter={StaticResource ActiveViewToUnderlineConverter}, ConverterParameter=User}"/>
                    </Button>
                </StackPanel>

                 <!-- User Profile / Window Controls Area -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" Margin="0,0,140,0">
                    <!-- Notifications -->
                    <material:MaterialIcon Kind="Bell" Width="18" Height="18" Foreground="{StaticResource SteamGreen}"/>
                    
                    <!-- Profile Name -->
                    <!-- Profile Name Input -->
                    <TextBox Text="{Binding PlayerName, Mode=TwoWay}" 
                             VerticalAlignment="Center" 
                             VerticalContentAlignment="Center"
                             Width="120"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource SteamBlueAccent}" 
                             FontWeight="Bold"
                             Padding="0"
                             Margin="0"
                             MinHeight="0"
                             SelectionBrush="{StaticResource SteamBlueDim}"
                             FontSize="14"/>
                               
                    <Border Width="32" Height="32" CornerRadius="2" Background="#24282f">
                        <material:MaterialIcon Kind="Account" Width="20" Height="20" Foreground="#8b929a" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <TransitioningContentControl Grid.Row="1" Content="{Binding CurrentPage}">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="0:0:0.25" />
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>
        
    </Grid>
</Window>

