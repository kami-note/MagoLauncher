<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MagoLauncher.Presentation.ViewModels"
             xmlns:controls="using:MagoLauncher.Presentation.Controls"
             xmlns:material="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MagoLauncher.Presentation.Views.HomeView"
             x:DataType="vm:HomeViewModel">
    <Grid ColumnDefinitions="260, *">
        <!-- Sidebar (Game List) -->
        <controls:Sidebar Grid.Column="0" Margin="0,0,1,0"/>
        
        <!-- Separator -->
        <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#1c2533"/>

        <!-- Main Game View -->
        <controls:GameDetailView Grid.Column="1"/>
    </Grid>
</UserControl>
